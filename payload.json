{
    "ComputeServers": {
        "My_GitHub_Account": {
            "FaaSType": "GitHubActions",
            "UserName": "dekkov",
            "ActionRepoName": "neon4cast_faasr_actions",
            "Branch": "main",
            "Token": "My_GitHub_Account_TOKEN"
        }
    },
    "DataStores": {
        "My_Minio_Bucket": {
            "Endpoint": "https://play.min.io",
            "Bucket": "faasr",
            "Region": "us-east-1",
            "Writable": "TRUE",
            "AccessKey": "My_Minio_Bucket_ACCESS_KEY",
            "SecretKey": "My_Minio_Bucket_SECRET_KEY"
        }
    },
    "FunctionList": {
        "getData": {
            "FunctionName": "get_target_data",
            "FaaSServer": "My_GitHub_Account",
            "Arguments": {
                "folder": "neon4cast",
                "output_target": "aquatic_full.csv",
                "output_blinded": "blinded_aquatic.csv"
            },
            "InvokeNext": [
                "oxygenForecast",
                "temperatureForecast"
            ]
        },
        "oxygenForecast": {
            "FunctionName": "create_oxygen_forecast",
            "FaaSServer": "My_GitHub_Account",
            "Arguments": {
                "folder": "neon4cast",
                "input_file": "blinded_aquatic.csv",
                "output_file": "oxygen_fc.csv"
            },
            "InvokeNext": "combineForecast"
        },
        "temperatureForecast": {
            "FunctionName": "create_temperature_forecast",
            "FaaSServer": "My_GitHub_Account",
            "Arguments": {
                "folder": "neon4cast",
                "input_file": "blinded_aquatic.csv",
                "output_file": "temperature_fc.csv"
            },
            "InvokeNext": "combineForecast"
        },
        "combineForecast": {
            "FunctionName": "combine_forecasts",
            "FaaSServer": "My_GitHub_Account",
            "Arguments": {
                "folder": "neon4cast",
                "input_oxygen": "oxygen_fc.csv",
                "input_temperature": "temperature_fc.csv",
                "output_file": "forecast_combined.csv"
            }
        }
    },
    "ActionContainers": {
        "getData": "ghcr.io/faasr/github-actions-tidyverse:1.4.1",
        "oxygenForecast": "ghcr.io/faasr/github-actions-tidyverse:1.4.1",
        "temperatureForecast": "ghcr.io/faasr/github-actions-tidyverse:1.4.1",
        "combineForecast": "ghcr.io/faasr/github-actions-tidyverse:1.4.1"
    },
    "FunctionGitRepo": {
        "get_target_data": "Ashish-Ramrakhiani/neon4cast_faasr",
        "create_oxygen_forecast": "Ashish-Ramrakhiani/neon4cast_faasr",
        "create_temperature_forecast": "Ashish-Ramrakhiani/neon4cast_faasr",
        "combine_forecasts": "Ashish-Ramrakhiani/neon4cast_faasr"
    },
    "FunctionInvoke": "getData",
    "FaaSrLog": "FaaSrLog",
    "LoggingDataStore": "My_Minio_Bucket",
    "DefaultDataStore": "My_Minio_Bucket",
    "FunctionGitHubPackage": {
        "get_target_data": [
            "tidyverts/tsibble",
            "eco4cast/neon4cast"
        ],
        "create_oxygen_forecast": [
            "tidyverts/tsibble",
            "eco4cast/neon4cast"
        ],
        "create_temperature_forecast": [
            "tidyverts/tsibble",
            "eco4cast/neon4cast"
        ],
        "combine_forecasts": [
            "tidyverts/tsibble",
            "eco4cast/neon4cast"
        ]
    },
    "FunctionCRANPackage": {
        "get_target_data": [
            "tidyverse",
            "fable"
        ],
        "create_oxygen_forecast": [
            "neon4cast",
            "tidyverse",
            "tsibble",
            "fable"
        ],
        "create_temperature_forecast": [
            "neon4cast",
            "tidyverse",
            "tsibble",
            "fable"
        ],
        "combine_forecasts": [
            "tidyverse",
            "glue"
        ]
    },
